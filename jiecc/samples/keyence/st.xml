	<MainBody>
		<BodyContent xsi:type="ST"><ST>// Operators






num := 2 + 3;
num := 2 - 3;
num := 2 * 3;
num := 2 / 3;
num := 3 mod 2;

lrealv := 2.0 ** 3.0;

wordv := wordv and uint#16#1010;

wordv := wordv &amp; uint#16#1010;

wordv := wordv or uint#16#1010;
wordv := wordv xor uint#16#1010;
boolv := boolv and true;

boolv := boolv &amp; false;

boolv := boolv or true;
boolv := boolv xor false;
boolv := 2 &lt; 3;
boolv := 2 &lt;= 3;
boolv := 2 = 3;
boolv := 2 &lt;&gt; 3;
boolv := 2 &gt;= 3;
boolv := 2 &gt; 3;
num := sv . m_0;




boolv := wordv . 3;

num := intv;




num := +intv;

num := -intv;
wordv := not wordv;
boolv := not boolv;







num := (intv);
num := ary[intv];

boolv := func(intv, 1, num);



boolv := func(i_1:=intv, i_2:=1, o=&gt;num);

// if statement.

if intv = 0 then
	num := num + 1;
end_if;

if (intv mod 2) = 0 then
	num := num + 2;
else
	num := num + 1;
end_if;

if intv &gt; 0 then
	num := +1;
elsif intv &lt; 0 then
	num := -1;
else
	num := 0;
end_if;

// case statement.

case intv of
2:
	num := 4;
3:
	num := 9;
4..7:
	num := intv * intv;
else
	num := 0;
end_case;

// for statement.

for intv := 1 to 4 by 1 do
	num := num + intv;
	// exit statement.
	if num &lt; -1 then
		exit;
	end_if;

	// continue statement.
	if num = 1 then
		continue;
	end_if;

end_for;

// while statement.

while intv &lt;= 10 do
	num := num + intv;
	intv := intv + 1;
end_while;

// repeat statement.

repeat
	num := num + intv;
	intv := intv + 1;
until intv = 15 end_repeat;
</ST></BodyContent>
